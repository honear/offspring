<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse MSIX manifest TEMPLATE for the Offspring Windows 11 modern
  right-click menu handler.

  "Sparse" means content (offspring.exe, offspring_shell_ext.dll, icons)
  lives at the path passed to `Add-AppxPackage -ExternalLocation <...>`.
  The MSIX file itself carries only this manifest + a small assets
  folder used for the appx registration UI.

  This file is a TEMPLATE consumed by `build-msix.ps1`, which generates
  three concrete manifests by substituting:
    __IDENTITY_NAME__   — package identity (Add-AppxPackage matches on
                          this; differs per variant so Win11 doesn't
                          auto-group multiple verbs under one parent)
    __DISPLAY_NAME__    — the label users see in the right-click menu
    __VERB_ID__         — desktop5:Verb Id (any unique string)
    __CLSID__           — both com:Class and desktop5:Verb point at it
    Version="…"         — bumped per build (regex-replaced)

  The three variants live in the same source tree because they share
  every other field. Each one signs separately but with the same cert.

  CLSIDs MUST match `shell-ext/src/lib.rs`:
    7A8B = ROOT_CLSID         (unified "Offspring")
    7A8C = PRESETS_ROOT_CLSID ("Offspring Presets")
    7A8D = TOOLS_ROOT_CLSID   ("Offspring Tools")

  Identity Name / Publisher are what Add-AppxPackage matches on — the
  cert CN must match Publisher exactly, and changing either field
  requires users to reinstall (Windows treats it as a new package).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  IgnorableNamespaces="uap uap3 uap10 rescap com desktop4 desktop5">

  <Identity
    Name="__IDENTITY_NAME__"
    Publisher="CN=Second March"
    Version="0.2.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>__DISPLAY_NAME__</DisplayName>
    <PublisherDisplayName>Second March</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <!-- Lets the package reference files (including the DLL) from the
         install directory passed via -ExternalLocation. -->
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Dependencies>
    <!-- 19041 = 20H1; earliest Windows 10 build that supports MSIX
         sparse packages + the fileExplorerContextMenus extension. -->
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
      Id="OffspringShellExt"
      Executable="offspring.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="__DISPLAY_NAME__"
        Description="Right-click video/image conversion presets powered by FFmpeg"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        AppListEntry="none">
        <uap:DefaultTile Wide310x150Logo="Assets\Square150x150Logo.png" />
      </uap:VisualElements>

      <Extensions>
        <!-- Register the in-proc COM server (our DLL). Threading model
             STA is required for shell extensions that touch UI.

             Exactly ONE CLSID per package. Three packages (Unified /
             Presets / Tools) means three independent MSIX identities,
             each registering its own single verb. Win11's modern menu
             only auto-groups when MULTIPLE verbs come from a single
             package, so this layout keeps each top-level entry
             ungrouped while still letting us register them selectively. -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Offspring Command">
              <com:Class
                Id="__CLSID__"
                Path="offspring_shell_ext.dll"
                ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!-- Attach the CLSID to the Windows 11 modern right-click menu
             for every file type. Children (preset / tool verbs) are
             driven dynamically by the DLL via IEnumExplorerCommand —
             nothing to list here. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="*">
              <desktop5:Verb
                Id="__VERB_ID__"
                Clsid="__CLSID__" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
