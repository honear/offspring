# Studio cargo target dir - build-release.ps1 directs the studio
# build pass here so the standard target dir isn't clobbered.
/target-studio/

# Microsoft-owned WebView2 Evergreen Bootstrapper. We redistribute
# it via the standard installer (Microsoft's terms allow this) but
# it doesn't belong in our git history. build-release.ps1 ensures
# it's present and downloads if missing; see RELEASING.md.
/installer/MicrosoftEdgeWebView2Setup.exe

*.pfx
*.p12
*.key
*.log

/DESIGN.md
/.claude/
/examples/
/OPERATIONS.md

# Minisign signing material. The private key must never enter the repo
# under any circumstances — losing it would let an attacker impersonate
# the maintainer once the pubkey is pinned in updates.rs. The public key
# file is also kept local-only because its canonical home is the
# `UPDATE_MINISIGN_PUBKEY` constant in src-tauri/src/updates.rs.
/installer/.minisign/
