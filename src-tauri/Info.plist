<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    macOS Info.plist additions, merged into the bundle by Tauri at
    build time. Currently just declares the NSServices entry that
    integration/services_mac.rs handles: "Offspring…" appears in
    Finder's right-click → Services submenu after the user enables
    it in System Settings → Keyboard → Keyboard Shortcuts → Services.

    NSPortName must match the value passed to
    [NSApp setServicesProvider:] — we set this implicitly via the
    OffspringServicesProvider class name; "Offspring" is the
    user-facing port label macOS uses to dispatch to us.

    NSMessage must match the Objective-C selector implemented in
    services_mac.rs — `openOffspringPicker` becomes
    `-openOffspringPicker:userData:error:` at the ObjC bridge.

    NSSendFileTypes restricts the menu entry to relevant file types
    so we don't pollute right-click menus on .txt / .pdf / etc.
-->
<plist version="1.0">
<dict>
    <!--
        LSUIElement = true makes Offspring an "agent" / "accessory"
        application: no icon in the Dock, no menu bar (the global one
        at the top of the screen), no application switcher entry —
        the app lives in the system menu bar instead. Set as the
        default state because the most common entry points are
        Finder right-click (Services) and the menu bar tray icon;
        neither benefits from a Dock presence.

        We bump the activation policy to "regular" dynamically when
        the user opens the main settings window (see
        integration/dock_mac.rs), so the Dock icon appears for the
        duration of that window and disappears again on close.
    -->
    <key>LSUIElement</key>
    <true/>

    <key>NSServices</key>
    <array>
        <dict>
            <key>NSMenuItem</key>
            <dict>
                <key>default</key>
                <string>Offspring…</string>
                <!--
                    Undocumented but historically-supported key on
                    NSMenuItem dicts in NSServices: refers to a PNG
                    in Contents/Resources/ by base name. macOS uses
                    it to render an icon next to the menu entry.
                    Honored inconsistently across macOS versions —
                    Apple's own Services menu styling is text-only,
                    and depending on the macOS build the renderer
                    may ignore this key entirely. We ship the file
                    via tauri.conf.json's bundle.resources so it
                    lands at the right path; if your macOS doesn't
                    paint it, no harm done — the menu still works.
                -->
                <key>image</key>
                <string>ServiceMenuIcon</string>
            </dict>
            <key>NSMessage</key>
            <string>openOffspringPicker</string>
            <key>NSPortName</key>
            <string>Offspring</string>
            <key>NSSendTypes</key>
            <array>
                <string>public.file-url</string>
            </array>
            <key>NSSendFileTypes</key>
            <array>
                <string>public.movie</string>
                <string>public.image</string>
                <string>public.audio</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
