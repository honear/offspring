{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "targets": ["dmg"],
    "category": "public.app-category.video",
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "infoPlist": {
        "NSServices": [
          {
            "NSMenuItem": {
              "default": "Offspring…"
            },
            "NSMessage": "openOffspringPicker",
            "NSPortName": "Offspring",
            "NSSendTypes": ["public.file-url"],
            "NSSendFileTypes": ["public.movie", "public.image", "public.audio"]
          }
        ]
      }
    }
  }
}
